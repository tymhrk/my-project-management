# ==========================================
# 2026 Project Management App Gitignore
# ==========================================

# --- OS & IDE ---
.DS_Store
.vscode/
.idea/
*.swp

# --- Backend (Rails) ---
backend/.env
backend/log/*.log
backend/tmp/
backend/storage/
backend/public/assets
backend/vendor/bundle
backend/bin/rspec
backend/coverage/

# 重要：マスターキーは絶対上げない
backend/config/master.key
backend/config/credentials/*.key

# SQLiteを使わなくても念のため（Neon/Postgresに一本化するため）
backend/db/*.sqlite3
backend/db/*.sqlite3-journal

# --- Frontend (Next.js) ---
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/.vercel
frontend/.env*

# --- Deployment / Misc ---
.env
.env.local
node_modules/
.bundle/
vendor/
